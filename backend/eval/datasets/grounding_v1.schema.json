{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ai-tutor/eval/grounding_v1.schema.json",
  "title": "Grounding Evaluation V1 Dataset",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "case_id",
      "course_id",
      "question",
      "answerability",
      "reference_answer",
      "gold_evidence",
      "category",
      "concept",
      "difficulty",
      "notes"
    ],
    "properties": {
      "case_id": {
        "type": "string",
        "minLength": 1
      },
      "course_id": {
        "type": "integer",
        "minimum": 1
      },
      "question": {
        "type": "string",
        "minLength": 1
      },
      "answerability": {
        "type": "string",
        "enum": [
          "answerable",
          "partially_answerable",
          "unanswerable"
        ]
      },
      "reference_answer": {
        "type": "string"
      },
      "gold_evidence": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "document",
            "relevant_text"
          ],
          "properties": {
            "document": {
              "type": "string",
              "minLength": 1
            },
            "document_id": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "chunk_ids": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1
              }
            },
            "page": {
              "type": "integer",
              "minimum": 1
            },
            "relevant_text": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "category": {
        "type": "string",
        "minLength": 1
      },
      "concept": {
        "type": [
          "string",
          "null"
        ]
      },
      "difficulty": {
        "type": "string",
        "enum": [
          "easy",
          "medium",
          "hard"
        ]
      },
      "notes": {
        "type": "string"
      }
    }
  }
}
