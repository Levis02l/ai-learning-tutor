{
  "experiment_id": "grounding_v1",
  "description": "Grounded RAG tutor vs ungrounded LLM baseline for reliability, traceability and refusal behaviour.",
  "dataset_path": "backend/eval/datasets/grounding_v1.json",
  "conditions": [
    "ungrounded",
    "grounded"
  ],
  "model": {
    "provider": "openai",
    "name": "configured-by-backend-env",
    "temperature": 0.0,
    "max_tokens": null
  },
  "retrieval": {
    "top_k": 5,
    "course_scoped": true
  },
  "versions": {
    "prompt_version": "grounding_v1",
    "policy_version": "not_applicable_for_chat_compare"
  },
  "outputs": {
    "run_directory_pattern": "backend/eval/results/{run_type}/{run_id}/",
    "run_config": "run_config.json",
    "raw_results_json": "raw_results.json",
    "raw_results_jsonl": "raw_results.jsonl",
    "summary_json": "summary.json",
    "summary_csv": "summary.csv",
    "manifest": "manifest.json",
    "human_annotations_csv": "backend/eval/results/grounding_v1_human_annotations.csv"
  },
  "notes": "Record the git commit hash and run timestamp in every generated result file."
}
